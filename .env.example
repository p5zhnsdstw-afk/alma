# Alma — Required Environment Variables
# Copy to .env and fill in values. NEVER commit the .env file.

# ── Server ────────────────────────────────────────────────────────────
ALMA_PORT=18790
ALMA_DATA_DIR=./data
NODE_ENV=production

# ── WhatsApp Business Cloud API (REQUIRED) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── LLM (REQUIRED) ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Google Calendar OAuth (optional — needed for calendar sync) ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (optional — needed for billing) ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OpenRouter (optional — fallback LLM) ──────────────────────────────
OPENROUTER_API_KEY=
