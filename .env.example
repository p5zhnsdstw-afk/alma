# Alma — Required Environment Variables
# Copy to .env and fill in values. NEVER commit the .env file.

# ── Server ────────────────────────────────────────────────────────────
ALMA_PORT=18790
ALMA_DATA_DIR=./data
NODE_ENV=production

# ── WhatsApp Business Cloud API (REQUIRED) ────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── LLM (REQUIRED) ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Google Calendar OAuth (optional — needed for calendar sync) ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Paddle (optional — needed for billing) ───────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_ID_ALMA=
PADDLE_PRICE_ID_FAMILIA=

# ── OpenRouter (optional — fallback LLM) ──────────────────────────────
OPENROUTER_API_KEY=
